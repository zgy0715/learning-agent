# ===== LLM 配置 =====
# 对话模型（OpenAI 兼容即可：DeepSeek / 通义 / 智谱 / ollama 等）
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# ===== MongoDB =====
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=a3_learning_agent

# ===== Embedding（真向量检索）=====
# DeepSeek 无 embedding 接口，故默认走本地 ollama，失败自动回退 sentence_transformers（纯 Python，离线可用）
# provider: ollama | sentence_transformers | openai_compatible
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=bge-m3
# 回退方案使用的本地模型（首次会自动下载，约 100MB）
EMBEDDING_ST_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=1024

# ===== Agent 调参 =====
RESOURCE_QUALITY_THRESHOLD=80
RESOURCE_MAX_REVISIONS=2
CRAG_RELEVANCE_THRESHOLD=0.5
CRAG_MIN_RELEVANT=1

# ===== 安全 =====
GUARDRAILS_ENABLED=true

# ===== 可观测性 =====
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8000
